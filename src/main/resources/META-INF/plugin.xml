<!-- Plugin Configuration File -->
<idea-plugin>
    <id>com.noisebomb.sqlalchemy.tools</id>
    <vendor url="https://github.com/no1sebomb">noisebomb</vendor>
    <!-- description is injected by patchPluginXml from README.md's "Plugin description" markers -->

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.python</depends>

    <extensions defaultExtensionNs="com.intellij">
        <defaultLiveTemplates
                file="liveTemplates/SQLAlchemy.xml"
        />
        <codeInsight.lineMarkerProvider
                language="Python"
                implementationClass="com.noisebomb.sqlalchemy.linemarkers.RelationshipLineMarkerProvider"
        />
    </extensions>

    <actions>
        <action id="GenerateSQLAlchemyModel"
                class="com.noisebomb.sqlalchemy.actions.GenerateModelAction"
                text="SQLAlchemy Model"
                description="Generate a new SQLAlchemy model"
                icon="/icons/tableMapping.svg">
            <add-to-group group-id="NewGroup" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
