<templateSet group="SQLAlchemy">

    <template name="colint"
              value="$NAME$: Mapped[int] = mapped_column(Integer)"
              description="Integer column"
              toReformat="true">
        <variable name="NAME" expression="" defaultValue="" alwaysStopAt="true"/>
        <context>
            <option name="PYTHON_CLASS" value="true"/>
        </context>
    </template>

    <template name="colint_legacy"
              value="$NAME$: Mapped[int] = Column(Integer)"
              description="Integer column (Legacy)"
              toReformat="true">
        <variable name="NAME" expression="" defaultValue="" alwaysStopAt="true"/>
        <context>
            <option name="Python" value="true"/>
            <option name="CLASS" value="true"/>
            <option name="STATEMENT" value="true"/>
        </context>
    </template>

    <template name="colstr"
              value="$NAME$: Mapped[str] = mapped_column(String)"
              description="String column"
              toReformat="true">
        <variable name="NAME" expression="" defaultValue="" alwaysStopAt="true"/>
        <context>
            <option name="Python" value="true"/>
            <option name="CLASS" value="true"/>
            <option name="STATEMENT" value="true"/>
        </context>
    </template>

    <template name="colstr_legacy"
              value="$NAME$: Mapped[str] = Column(String)"
              description="String column (Legacy)"
              toReformat="true">
        <variable name="NAME" expression="" defaultValue="" alwaysStopAt="true"/>
        <context>
            <option name="Python" value="true"/>
            <option name="CLASS" value="true"/>
            <option name="STATEMENT" value="true"/>
        </context>
    </template>

    <template name="col"
              value="$NAME$: Mapped[$TYPE$] = mapped_column($SQL_TYPE$)"
              description="Column"
              toReformat="true">
        <variable name="NAME" expression="" defaultValue="" alwaysStopAt="true"/>
        <variable name="TYPE" expression="" defaultValue="" alwaysStopAt="true"/>
        <variable name="SQL_TYPE" expression="" defaultValue="" alwaysStopAt="true"/>
        <context>
            <option name="Python" value="true"/>
            <option name="CLASS" value="true"/>
            <option name="STATEMENT" value="true"/>
        </context>
    </template>

    <template name="col_legacy"
              value="$NAME$: Mapped[$TYPE$] = Column($SQL_TYPE$)"
              description="Column (Legacy)"
              toReformat="true">
        <variable name="NAME" expression="" defaultValue="" alwaysStopAt="true"/>
        <variable name="TYPE" expression="" defaultValue="" alwaysStopAt="true"/>
        <variable name="SQL_TYPE" expression="" defaultValue="" alwaysStopAt="true"/>
        <context>
            <option name="Python" value="true"/>
            <option name="CLASS" value="true"/>
            <option name="STATEMENT" value="true"/>
        </context>
    </template>

    <template name="rel"
              value="$NAME$: Mapped[&quot;$REL_TYPE$&quot;] = relationship(&#10;&quot;$REL_TYPE$&quot;,&#10;back_populates=$BACKREF$,&#10;uselist=False,&#10;)"
              description="Relationship"
              toReformat="true">
        <variable name="NAME" expression="" defaultValue="" alwaysStopAt="true"/>
        <variable name="REL_TYPE" expression="" defaultValue="" alwaysStopAt="true"/>
        <variable name="BACKREF" expression="" defaultValue="None" alwaysStopAt="true"/>
        <context>
            <option name="Python" value="true"/>
            <option name="CLASS" value="true"/>
            <option name="STATEMENT" value="true"/>
        </context>
    </template>

    <template name="relmany"
              value="$NAME$: Mapped[list[&quot;$REL_TYPE$&quot;]] = relationship(&#10;&quot;$REL_TYPE$&quot;,&#10;back_populates=$BACKREF$,&#10;uselist=True,&#10;)"
              description="Relationship (many)"
              toReformat="true">
        <variable name="NAME" expression="" defaultValue="" alwaysStopAt="true"/>
        <variable name="REL_TYPE" expression="" defaultValue="" alwaysStopAt="true"/>
        <variable name="BACKREF" expression="" defaultValue="None" alwaysStopAt="true"/>
        <context>
            <option name="Python" value="true"/>
            <option name="CLASS" value="true"/>
            <option name="STATEMENT" value="true"/>
        </context>
    </template>
</templateSet>
